# Copier vers /etc/ipastore/prod.env et remplir les valeurs.
# NE PAS COMMITTER les fichiers .env reels.
#
# En pratique ce fichier est ecrit automatiquement par le bootstrap
# (deploy/bootstrap.sh) — ne le touche a la main qu'en debug / override
# manuel.

# La connexion BDD (host/user/mdp/nom de base) est configuree via l'UI admin
# a la premiere connexion (/setup/database) et persistee dans /etc/ipastore/db.json.

# Racine du stockage (IPAs, icones, screenshots). Monte en volume dans le conteneur.
IPASTORE_STORE_DIR=/srv/store

# Fichier contenant la cle de session (generee automatiquement au 1er demarrage).
IPASTORE_SECRET_FILE=/etc/ipastore/secret_key.prod

# URL publique du serveur, utilisee dans source.json et les liens d'install.
# OPTIONNEL : si absent, l'app lit request.base_url (via --proxy-headers
# + --forwarded-allow-ips=*) pour deriver dynamiquement l'URL publique.
# A ne definir que si tu veux forcer une URL (reverse proxy sans X-Forwarded
# correctement configure, ou URL differente du host qui recoit la requete).
# IPASTORE_BASE_URL=http://192.168.0.210

# Environnement logique (prod|dev), utilise par les scripts de build SCInsta
# pour nommer les fichiers flag et les conteneurs builder.
IPASTORE_ENV=prod

# Repo GitHub utilise pour le check de mise a jour.
IPASTORE_GITHUB_REPO=MattTen/sideserver_website
