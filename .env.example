# Copier vers /etc/ipastore/prod.env ou /etc/ipastore/dev.env
# et remplir les valeurs. NE PAS COMMITTER les fichiers .env réels.

# La connexion BDD (host/user/mdp/nom de base) est configurée via l'UI admin
# à la première connexion (/setup/database) et persistée dans /etc/ipastore/db.json.
# Pour forcer une BDD dès le boot (ancien mode), décommenter :
# IPASTORE_DB_URL=mysql+pymysql://ipastore:CHANGE_ME@host.docker.internal:3306/ipastore-prod?charset=utf8mb4

# Racine du stockage (IPAs, icônes, screenshots). Monté en volume dans le conteneur.
IPASTORE_STORE_DIR=/srv/store

# Fichier contenant la clé de session (générée automatiquement au 1er démarrage).
IPASTORE_SECRET_FILE=/etc/ipastore/secret_key

# URL publique du serveur, utilisée dans source.json et les liens d'install.
IPASTORE_BASE_URL=http://192.168.0.202
